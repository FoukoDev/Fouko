# Copy this file to .env and fill in whatever platforms / services you want.
# The bot picks up every token that is set and silently skips the rest.
# .env is gitignored, .env.example is the template that ships with the repo.

# --- Platforms ---------------------------------------------------------------

# Telegram: get one from @BotFather
TG_TOKEN=

# Discord: create an application, then Bot -> Reset Token
DISCORD_TOKEN=

# --- Storage -----------------------------------------------------------------
# Storage backend URL. If you leave this empty, FoukoApi creates a SQLite
# file next to the binary (foukoapi.sqlite) on first launch. Supported:
#   sqlite:/path/to/file.db       local SQLite file (auto-created)
#   memory:                       in-memory, lost on restart
#   postgres://user:pass@host/db  external driver (bring your own Storage impl)
# FOUKO_DB=sqlite:./foukobot.sqlite

# --- Services ----------------------------------------------------------------

# OpenWeatherMap API key (https://openweathermap.org/).
# Leave empty to disable the /weather command.
OPEN_WEATHER_KEY=

# --- Logging -----------------------------------------------------------------
# RUST_LOG=info,foukoapi=info,foukobot=debug
